# Optional — copy this file to .env and fill in values if needed.
# The scraper itself does not require any secrets, but you may want to
# set environment variables to customise behaviour without editing source code.

# Path to the ChromeDriver binary (leave empty to use PATH)
# CHROMEDRIVER_PATH=

# Override the Chrome/Chromium binary location globally
# CHROME_BINARY=

# Comma-separated list of shops to run by default
# PRICE_PULSE_SHOPS=adidas,zalando
